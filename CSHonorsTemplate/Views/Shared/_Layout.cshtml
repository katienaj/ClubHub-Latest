@using CSHonorsTemplate.Models
@using CSHonorsTemplate.Utilities
@inject IMiscHelper MiscHelper
@{
    UserInfo userInfo = MiscHelper.GetUserInfo();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Culver Clubhub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CSHonorsTemplate.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Culver Clubhub</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="UserInfo">User Info</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Clubs" asp-action="Index">Clubs</a>
                        </li>
                        @if (userInfo != null && userInfo.isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="AdminPage">Admin Page</a>
                            </li>
                        }
                    </ul>
                    @if (User.Identity.IsAuthenticated)
                    {
                        var impersonatedUserId = Context.Session.GetString("ImpersonatedUser");
                        var userIdToDisplay = !string.IsNullOrEmpty(impersonatedUserId) ? impersonatedUserId : User.Identity.Name;

                        <ul class="nav navbar-nav ms-auto">
                            <li class="navbar-text">Logged in user: @userIdToDisplay &nbsp;&nbsp; </li>
                            @if (impersonatedUserId != null)
                            {
                                <li class="navbar-text">(Impersonating) </li>
                                <li class="navbar-btn">
                                    <a asp-controller="Settings" asp-action="ClearImpersonation" class="btn btn-warning">Stop Impersonating</a>
                                </li>
                            }
                            @if (userInfo != null && userInfo.isAdmin)
                            {
                                <li class="navbar-btn">
                                    <a asp-controller="Settings" asp-action="Index" class="btn btn-secondary">Settings</a>
                                </li>
                            }
                            <li class="navbar-btn">
                                <a id="logoutForm" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut" method="post" class="btn btn-primary">Sign-Out</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - CSHonorsTemplate - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/1cf0e4df44.js" crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.js" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
