@{
    ViewData["Title"] = "Permission Denied";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <i class="fas fa-ban fa-5x text-danger mb-4"></i>
        <h1 class="display-4 text-danger">Role Error</h1>
        <p class="lead mt-3 mb-4">
            Unable to assign role (@ViewData["Role"]) to member (@ViewData["Name"]).<br />
            If you believe this is an error, please contact your administrator.
        </p>
        <a asp-controller="Clubs" asp-action="Details" asp-route-id="@( (int)ViewData["ClubID"] )" class="btn btn-primary">
            <i class="fas fa-home"></i> Return to Club
        </a>
    </div>
</div>